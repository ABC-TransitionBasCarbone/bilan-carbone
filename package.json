{
  "name": "bilan-carbone",
  "version": "2.7.0",
  "private": true,
  "engines": {
    "node": "22.16.0",
    "yarn": "1.22"
  },
  "scripts": {
    "postinstall": "cd publicodes-packages/publicodes-count && yarn install && yarn run compile && cd ../../ && cd publicodes-packages/publicodes-clickson && yarn install && yarn run compile",
    "dev": "next dev --turbopack",
    "dev:test": "dotenv -e .env.test -- next dev --turbopack --port 3001",
    "build": "next build",
    "start": "next start",
    "ts": "tsc --noEmit",
    "lint": "prettier --check . && next lint",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "publicodes-count:compile": "cd publicodes-packages/publicodes-count && yarn run compile",
    "publicodes-count:watch": "cd publicodes-packages/publicodes-count && yarn run watch ",
    "publicodes-count:test": "cd publicodes-packages/publicodes-count && yarn test",
    "publicodes-count:translate": "yarn run publicodes-count:compile && npx tsx src/i18n/publicodes/generate-translation-file.tsx -m cut",
    "publicodes-clickson:compile": "cd publicodes-packages/publicodes-clickson && yarn run compile",
    "publicodes-clickson:watch": "cd publicodes-packages/publicodes-clickson && yarn run watch ",
    "publicodes-clickson:test": "cd publicodes-packages/publicodes-clickson && yarn test",
    "publicodes-clickson:translate": "yarn run publicodes-clickson:compile && npx tsx src/i18n/publicodes/generate-translation-file.tsx -m clickson",
    "cypress": "cypress run",
    "cypress:gui": "cypress open",
    "db:test:reset": "dotenv -e .env.test -- prisma migrate reset --force",
    "seed:import": "prisma db seed -- -i",
    "question:import:google": "npx tsx src/scripts/cut/question/add.ts -s google -f",
    "question:import:excel": "npx tsx src/scripts/cut/question/add.ts -f",
    "user:import": "tsx src/scripts/ftp/importUsers.ts"
  },
  "prisma": {
    "schema": "prisma/schema",
    "seed": "tsx prisma/seed/index.ts"
  },
  "dependencies": {
    "@abc-transitionbascarbone/publicodes-clickson": "file:./publicodes-packages/publicodes-clickson/",
