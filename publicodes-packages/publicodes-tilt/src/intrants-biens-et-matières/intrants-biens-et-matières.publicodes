intrants-biens-et-matières:

intrants-biens-et-matières . biens-et-matières ratio monétaire:
  titre: Intrants biens et matières
  question: Quels biens et matières avez-vous achetés en approche monétaire en [Année] ?
  formule:
    somme:
      - petites-fournitures
      - meubles
      - machines-équipements
      - textiles
      - produits-pharmaceutiques
      - produits-chimiques
      - papier-carton
      - produits-métalliques
      - autres-produits-manufacturés
  unité: kgCO2e

intrants-biens-et-matières . biens-et-matières ratio monétaire . petites-fournitures:
  formule: nombre * FE
  avec:
    nombre:
      question: Montant dépensé (k€) en petites fournitures
      par défaut: 0
      unité: k€

    FE:
      valeur: 367
      unité: kgCO2e/k€ HT
      meta:
        nom: Petites Fournitures
        id: 20556
  unité: kgCO2e

