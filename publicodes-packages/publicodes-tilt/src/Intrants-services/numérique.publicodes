  unité: kgCO2e

intrants-services . numérique . stockage-cloud:
  formule: volume * FE
  avec:
    volume:
      question: Combien de Go de données stockées sur le cloud ?
      par défaut: 0
      unité: Go

    FE:
      valeur: 0.0116
      unité: kgCO2e/Go
