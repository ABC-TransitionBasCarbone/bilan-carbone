immobilisations . rénovation:
  titre: Rénovation
  formule:
    somme:
      - bâtiment scolaire structure béton rénové
      - parking bâtiment structure béton rénové
      - parking surface bitume rénové
      - parking surface semi-dure rénové
      - garage structure béton rénové
      - garage structure métal rénové
  unité: kgCO2e
  par défaut: 0
  avec:
    bâtiment scolaire structure béton rénové:
      titre: "Bâtiment scolaire rénové (structure béton)"
      formule:
        variations:
          - si: age > amortissement
            alors: 0
          - sinon: surface * FE / amortissement
      unité: kgCO2e
      par défaut: 0
      avec:
        age:
          durée:
            unité: an
            par défaut: 0
            depuis: général . année de rénovation
            jusqu'à: commun . année actuelle
          arrondi: oui
        amortissement:
          valeur: 25
          note: Amortissement annuel sous-entendu (rénovation).
        surface:
          question: "Quelle surface de bâtiment scolaire (structure béton) avez-vous rénovée ?"
          unité: m2
          par défaut: 0
        FE:
          question: "Facteur d'émission par m² de bâtiment scolaire rénové (structure béton)"
          valeur: 220
          unité: kgCO2e/m2
          par défaut: 0
          note: |
            Source: Base Carbone®
          meta:

    parking bâtiment structure béton rénové:
      titre: "Parking rénové (bâtiment - structure béton)"
      formule: surface * FE
      unité: kgCO2e
      par défaut: 0
      avec:
        surface:
          question: "Quelle surface de parking (bâtiment - structure béton) avez-vous rénovée ?"
          unité: m2
          par défaut: 0
        FE:
          question: "Facteur d'émission par m² de parking rénové (bâtiment - structure béton)"
          valeur: 160
          unité: kgCO2e/m2
          par défaut: 0
          note: |
            Source: Base Carbone®
          meta:

    parking surface bitume rénové:
