          - si: type = "CH4 biogénique"
            alors: type . CH4 biogénique . FE
          - si: type = "N2O"
            alors: type . N2O . FE
          - si: type = "SF6"
            alors: type . SF6 . FE
          - si: type = "NF3"
            alors: type . NF3 . FE
      unité: kgCO2e/kg

