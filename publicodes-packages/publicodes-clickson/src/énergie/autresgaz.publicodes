énergie . autres gaz:
  titre: Autres gaz
  formule:
    somme:
      - gaz réfrigérants
      - gaz effet de serre principaux
  unité: kgCO2e/kg
  par défaut: 0

énergie . autres gaz . gaz réfrigérants:
  titre: Gaz réfrigérants
  question: Consommation annuelle de gaz réfrigérant
  par défaut: 0
  unité: kgCO2e/kg
  formule: gaz réfrigérant

énergie . autres gaz . gaz réfrigérant:
  titre: Gaz réfrigérant
  par défaut: 0
  unité: kgCO2e/kg
  formule: consommation * FE
  avec:
    consommation:
      question: Consommation annuelle de ce gaz
      unité: kgCO2e/kg
      par défaut: 0
    FE:
      titre: Facteur d'émission du projecteur
      formule:
        variations:
          - si: type = "R134a"
            alors: type . R134a . FE
          - si: type = "R32"
            alors: type . R32 . FE
          - si: type = "R407c"
            alors: type . R407c . FE
          - si: type = "R410a"
            alors: type . R410a . FE
      unité: kgCO2e/kg

énergie . autres gaz . gaz réfrigérant . type:
  titre: Gaz réfrigérant
  question: Gaz réfrigérant
  une possibilité:
    - R134a
    - R32
    - R407c
    - R410a
  form:
    saisie: menu déroulant
