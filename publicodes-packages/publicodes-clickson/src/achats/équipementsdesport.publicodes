achats . équipements de sport . ballon de volley:
  titre: "Ballon de volley"
  formule: nombre * FE
  unité: kgCO2e
  par défaut: 0
  avec:
    nombre:
      question: "Combien de ballons de volley avez-vous achetés ?"
      unité: unité
      par défaut: 0
    FE:
      question: "Facteur d'émission par ballon de volley"
      valeur: 2.25
      unité: kgCO2e/unité
      note: |
        Source: Base Carbone®
      meta:
        incertitude: 3

