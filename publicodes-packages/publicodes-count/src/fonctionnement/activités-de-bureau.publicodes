fonctionnement . activités de bureau:
  titre: Activités de bureau
  formule:
    somme:
      - petites fournitures
      - services
      - informatique
  unité: kgCO2e

fonctionnement . activités de bureau . petites fournitures:
  titre: Petites fournitures de bureau
  formule:
    produit:
      - montant
      - FE
  par défaut: 0
  unité: kgCO2e
  avec:
    montant:
      question: |
        Quel montant avez-vous dépensé en petites fournitures de bureau ? (Exemples: crayon, cartouche d’encre, papier hors programme, cahier, etc.)
      unité: €

    FE:
      valeur: 0.367
      unité: kgCO2e/€
      meta:
        id: 20556

fonctionnement . activités de bureau . services:
  titre: Services
  formule:
    produit:
      - montant
      - FE
  par défaut: 0
  unité: kgCO2e
  note: Conversion auto €/k€ publicodes.
  avec:
    montant:
      question: Quel montant avez-vous dépensé en services ?
      description: |
        Les services incluent par exemple les dépenses de ménage, sécurité, comptabilité, frais bancaires, etc. Vous pouvez utiliser une valeur par défaut pour cette réponse (25286€) qui est issue des Bilans Carbone® qui ont étés réalisés sur plusieurs cinémas français. Si vous détenez une information plus précise pour votre cinéma, nous vous invitons à l'utiliser plutôt que la valeur par défaut.
      unité: €

    FE:
      valeur: 67
      unité: kgCO2e/k€
      meta:
        id: 43545

fonctionnement . activités de bureau . informatique:
  titre: Informatique
  unité: kgCO2e
  question: Pour chacun de ces équipements informatiques, veuillez indiquer leur nombre et leur date d'achat ou durée de location
  description: |
    Si l'équipement concerné est acheté, merci de ne pas remplir le champ "Durée de location". Si l'équipement concerné est loué de manière ponctuelle, merci de ne pas remplir le champ "Date d'achat". Si vous louez un équipement pour de longues durées ou de manière continue, nous vous recommandons de le considérer comme acheté (à la date de la première année de location).
  note: La durée de location prévaut sur la date d'achat.
  # TODO: Should be a list of appareil
  formule: appareil
  par défaut: 0

fonctionnement . activités de bureau . informatique . appareil:
  titre: Empreinte appareil informatique type
  description: |
    Calcul de l'empreinte d'un appareil informatique type en fonction de son nombre, de sa date d'achat ou de sa durée de location.
    Règle de calcul utilisée pour chaque type d'appareil informatique.
  formule:
    variations:
      - si:
          est défini: durée location
        alors:
          produit:
            - nombre
            - FE
            - (durée location / (commun . nombre de jours par an * 1 /an * amortissement))
      - sinon:
          variations:
            - si: age > amortissement
              alors: 0
            - sinon: nombre * FE / amortissement
  par défaut: 0
  unité: kgCO2e
  avec:
    age:
      durée:
        depuis: année achat
        jusqu'à: commun . année actuelle
      arrondi: oui
      unité: an

    nombre:
      question: Nombre d'appareils

    année achat:
      non applicable si:
        est défini: durée location
      question: Année d'achat des appareils
      type: date
      form:
        saisie: année

    durée location:
      question: Durée de location des appareils (jours à l'année)
      unité: jour

    amortissement:
      valeur: 5
      unité: an
      note: La durée d'amortissement est la même pour tous les appareils informatiques et fixée à 5 ans.

    FE:
      formule:
        variations:
          - si: équipement = "ordinateurs fixes"
            alors: équipement . ordinateurs fixes . FE
          - si: équipement = "ordinateurs portables"
            alors: équipement . ordinateurs portables . FE
          - si: équipement = "photocopieurs"
            alors: équipement . photocopieurs . FE
          - si: équipement = "imprimantes"
            alors: équipement . imprimantes . FE
          - si: équipement = "téléphones fixes"
            alors: équipement . téléphones fixes . FE
          - si: équipement = "téléphones portables"
            alors: équipement . téléphones portables . FE
          - si: équipement = "tablettes"
            alors: équipement . tablettes . FE
      unité: kgCO2e

