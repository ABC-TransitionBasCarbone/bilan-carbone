{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "target": "ES2017",
    "incremental": true,
    "paths": {
      "@repo/db-common": ["packages/db-common/src/index.ts"],
      "@repo/db-common/enums": ["packages/db-common/src/enums.ts"],
      "@repo/db-common/types": ["packages/db-common/src/types.ts"]
    }
  }
}
