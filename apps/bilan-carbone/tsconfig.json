{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": ".next/cache/tsbuildinfo.json",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@repo/db-common": ["../../packages/db-common/src/index.ts"],
      "@repo/db-common/enums": ["../../packages/db-common/src/enums.ts"],
      "@repo/db-common/types": ["../../packages/db-common/src/types.ts"],
      "@abc-transitionbascarbone/publicodes-count": ["./publicodes-packages/publicodes-count"],
      "@abc-transitionbascarbone/publicodes-clickson": ["./publicodes-packages/publicodes-clickson"],
      "@abc-transitionbascarbone/publicodes-tilt": ["./publicodes-packages/publicodes-tilt"]
    }
  },
  "ts-node": {
    "experimentalResolver": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".next/dev/types/**/*.ts", "**/*.mts"],
  "exclude": ["node_modules", "publicodes-packages"]
}
