{
  "name": "bilan-carbone",
  "version": "2.7.0",
  "private": true,
  "engines": {
    "node": "22.16.0",
    "yarn": "1.22"
  },
  "scripts": {
    "postinstall": "yarn install --production=false --cwd publicodes-packages/publicodes-count && yarn install --production=false --cwd publicodes-packages/publicodes-clickson && yarn install --production=false --cwd publicodes-packages/publicodes-tilt && prisma generate --config ../../packages/db-common/prisma.config.ts",
    "dev": "next dev",
    "dev:test": "dotenv -e .env.test -- next dev --port 3001",
    "start:test": "dotenv -e .env.test -- env PORT=3001 node .next/standalone/apps/bilan-carbone/server.js",
    "prebuild": "yarn run publicodes-tilt:compile && yarn run publicodes-count:compile && yarn run publicodes-clickson:compile",
    "build": "next build && node copy-assets.js",
    "start": "node -r dotenv/config .next/standalone/apps/bilan-carbone/server.js dotenv_config_path=.env",
    "ts": "tsc --noEmit",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "publicodes-count:compile": "cd publicodes-packages/publicodes-count && yarn run compile",
    "publicodes-count:watch": "cd publicodes-packages/publicodes-count && yarn run watch ",
    "publicodes-count:test": "cd publicodes-packages/publicodes-count && yarn test",
    "publicodes-count:translate": "yarn run publicodes-count:compile && npx tsx src/i18n/publicodes/generate-translation-file.tsx -m cut",
    "publicodes-clickson:compile": "cd publicodes-packages/publicodes-clickson && yarn run compile",
    "publicodes-clickson:watch": "cd publicodes-packages/publicodes-clickson && yarn run watch ",
    "publicodes-clickson:test": "cd publicodes-packages/publicodes-clickson && yarn test",
    "publicodes-clickson:translate": "yarn run publicodes-clickson:compile && npx tsx src/i18n/publicodes/generate-translation-file.tsx -m clickson",
    "publicodes-tilt:compile": "cd publicodes-packages/publicodes-tilt && yarn run compile",
    "publicodes-tilt:watch": "cd publicodes-packages/publicodes-tilt && yarn run watch ",
    "publicodes-tilt:test": "cd publicodes-packages/publicodes-tilt && yarn test",
    "publicodes-tilt:translate": "yarn run publicodes-tilt:compile && npx tsx src/i18n/publicodes/generate-translation-file.tsx -m tilt",
    "cypress": "cypress run",
    "cypress:gui": "cypress open",
    "db:test:reset": "dotenv -e .env.test -- prisma migrate reset --force --schema=../../packages/db-common/prisma/schema/schema.prisma && dotenv -e .env.test -- tsx prisma/seed/index.ts",
    "seed:import": "prisma db seed -- -i",
    "question:import:google": "npx tsx src/scripts/cut/question/add.ts -s google -f",
    "question:import:excel": "npx tsx src/scripts/cut/question/add.ts -f"
  },
  "prisma": {
    "seed": "tsx prisma/seed/index.ts"
  },
  "dependencies": {
    "@abc-transitionbascarbone/publicodes-clickson": "file:./publicodes-packages/publicodes-clickson/",
    "@abc-transitionbascarbone/publicodes-count": "file:./publicodes-packages/publicodes-count/",
    "@abc-transitionbascarbone/publicodes-tilt": "file:./publicodes-packages/publicodes-tilt/",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/material-nextjs": "^7.3.8",
    "@mui/x-charts": "^8.28.0",
    "@mui/x-date-pickers": "^8.27.2",
    "@prisma/client": "^7.7.0",
    "@publicodes/forms": "^0.6.1",
    "@repo/types": "*",
    "@repo/ui": "*",
    "@smithy/config-resolver": "^4.4.14",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-gauge-chart": "^0.5.0",
    "axios": "^1.15.0",
    "basic-ftp": "^5.2.2",
    "bcryptjs": "^3.0.3",
    "big.js": "^7.0.1",
    "classnames": "^2.5.1",
    "commander": "^14.0.3",
    "dayjs": "^1.11.19",
    "docxtemplater": "^3.68.4",
    "dompurify": "^3.3.1",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "excel-date-to-js": "^1.1.5",
    "file-type": "^22.0.1",
    "fuse.js": "^7.3.0",
    "jsonwebtoken": "^9.0.3",
    "mui-color-input": "^8.0.0",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "next-intl": "^4.9.1",
    "node-xlsx": "^0.24.0",
    "nodemailer": "^8.0.5",
    "pizzip": "^3.2.0",
    "postcss": "^8.5.9",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.2.1",
    "preact": "^10.29.1",
    "prisma": "^7.7.0",
    "publicodes": "^1.10.1",
    "react": "19.2.5",
    "react-countdown": "^2.3.6",
    "react-dom": "19.2.5",
    "react-gauge-chart": "^0.5.1",
    "react-hook-form": "^7.72.1",
    "react-player": "^3.4.0",
    "server-only": "^0.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^10.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/big.js": "^6.2.2",
    "@types/ejs": "^3.1.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "csv-parse": "^6.2.1",
    "cypress": "^15.13.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-prisma": "^5.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "yargs": "^18.0.0"
  },
  "resolutions": {
    "@hono/node-server": "^1.19.13"
  }
}
