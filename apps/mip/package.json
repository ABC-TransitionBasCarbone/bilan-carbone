{
  "name": "mip",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.16.0",
    "yarn": "1.22"
  },
  "scripts": {
    "postinstall": "yarn install --production=false --cwd ../../packages/publicodes-packages/publicodes-mip && prisma generate --config ../../packages/db-common/prisma.config.ts",
    "dev": "next dev --port 3002",
    "prebuild": "yarn run publicodes-mip:compile",
    "build": "next build",
    "start": "next start --port 3002",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "ts": "tsc --noEmit",
    "publicodes-mip:compile": "cd ../../packages/publicodes-packages/publicodes-mip && yarn run compile",
    "publicodes-mip:watch": "cd ../../packages/publicodes-packages/publicodes-mip && yarn run watch ",
    "publicodes-mip:test": "cd ../../packages/publicodes-packages/publicodes-mip && yarn test",
    "publicodes-mip:translate": "yarn run publicodes-mip:compile && npx tsx ../../packages/i18n/publicodes/generate-translation-file.tsx -m mip"
  },
  "dependencies": {
    "@abc-transitionbascarbone/components": "*",
    "@abc-transitionbascarbone/lib": "*",
    "@abc-transitionbascarbone/typeguards": "*",
    "@abc-transitionbascarbone/ui": "*",
    "@abc-transitionbascarbone/utils": "*",
    "@abc-transitionbascarbone/publicodes": "*",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/material-nextjs": "^7.3.8",
    "@mui/x-date-pickers": "^8.27.2",
    "dayjs": "^1.11.19",
    "next": "16.2.6",
    "next-intl": "^4.11.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.72.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13",
    "publicodes": "^1.10.1",
    "@publicodes/forms": "^0.6.1",
    "@base-ui-components/react": "^1.0.0-rc.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@types/node": "^25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "^11.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "typescript": "^6.0.2"
  }
}
