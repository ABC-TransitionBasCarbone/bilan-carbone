model Actuality {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  title     String
  text      String

  language String @default("fr")

  @@map("actualities")
  @@schema("bilan_carbone")
}
