model AccountMip {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  status    UserStatus
  role Role
  organizationVersionMip           OrganizationVersionMip?  @relation(fields: [organizationVersionMipId], references: [id])
  organizationVersionMipId         String?                  @map("organization_version_mip_id")

  environment Environment @default(MIP)

  @@unique([userId, environment])
  @@map("accounts_mip")
  @@schema("mip")
}
