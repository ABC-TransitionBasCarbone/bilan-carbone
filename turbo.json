{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false
    },
    "ts": {},
    "lint": {},
    "prisma": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "test": {
      "cache": false
    }
  }
}
